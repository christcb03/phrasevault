# Local archive of pre-refactor artifacts (not part of the build)
old/

# Rust
/target/
**/target/

# Node.js
node_modules/
dist/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# PhraseVault — never commit real data
*.db
*.db-journal
*.db-wal
*.db-shm
*.pvx

# Forest files — only examples/ should contain JSON
*.json
!examples/*.json
!pyproject.toml
!package.json
!package-lock.json
!tsconfig*.json
!terraform.tfvars.example

# Secrets
.env
.env.*
secrets/
*.key
*.pem

# Tests
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Ansible — local inventory (copy from inventory.example.ini; never commit)
deploy/ansible/inventory.ini
deploy/ansible/inventory.local.ini

# Pipeline artifacts (fetched test logs)
deploy/ansible/artifacts/
